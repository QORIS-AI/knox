{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "failClosed": true, "timeout": 10 }
    ],
    "beforeMCPExecution": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "failClosed": true, "timeout": 5 }
    ],
    "beforeReadFile": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 5 }
    ],
    "preToolUse": [
      { "matcher": "Write|Edit|MultiEdit|NotebookEdit", "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 5 }
    ],
    "beforeSubmitPrompt": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 3 }
    ],
    "sessionStart": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 3 }
    ],
    "sessionEnd": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 3 }
    ],
    "subagentStop": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 3 }
    ],
    "stop": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 3 }
    ],
    "preCompact": [
      { "command": "${CURSOR_PLUGIN_ROOT}/bin/run-check-cursor.sh", "timeout": 3 }
    ]
  }
}
