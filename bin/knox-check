#!/usr/bin/env node
'use strict';
const { checkCommand, checkWritePath, checkReadPath, checkInjection, isCheckDisabled } = require('../lib/check');
const { loadConfig, PLUGIN_DATA } = require('../lib/config');
const { writeAudit } = require('../lib/audit');
const { incrementDenial, recordCrossDenial } = require('../lib/state');

let inputData = '';
process.stdin.on('data', chunk => { inputData += chunk; });
process.stdin.on('end', () => {
  let event;
  try { event = JSON.parse(inputData); } catch { process.exit(0); }

  const config = loadConfig();
  const sessionId = event.session_id || 'unknown';
  const toolName = event.tool_name || '';
  const input = event.tool_input || {};

  let result = null;

  // Route by tool name
  if (['Bash', 'Monitor', 'PowerShell', 'Shell'].includes(toolName)) {
    const command = input.command || '';
    result = checkCommand(command, config);
  } else if (toolName === 'Read') {
    if (!isCheckDisabled(config, 'read_path_protection')) {
      const filePath = input.file_path || input.path || '';
      result = checkReadPath(filePath, config);
      if (result) result.risk = 'high';
    }
  } else if (['Write', 'Edit', 'NotebookEdit'].includes(toolName)) {
    const filePath = input.file_path || input.path || '';
    result = checkWritePath(filePath, config);
  } else if (toolName === 'MultiEdit') {
    // MultiEdit has a top-level file_path AND edits array with per-edit paths
    const paths = [input.file_path, ...((input.edits || []).map(e => e.file_path))].filter(Boolean);
    for (const fp of paths) {
      result = checkWritePath(fp, config);
      if (result) break;
    }
  } else if (toolName.startsWith('mcp__')) {
    if (!isCheckDisabled(config, 'mcp_inspection')) {
      const values = extractStringValues(input);
      for (const v of values) {
        const r = checkInjection(v, config);
        if (r) { result = { blocked: true, reason: r.reason, ruleId: r.id, risk: 'high' }; break; }
      }
    }
  }

  if (result && result.blocked) {
    const isCritical = result.risk === 'critical' || result.critical;

    // Audit the denial
    const previewStr = input.command || input.file_path || JSON.stringify(input);
    writeAudit(config.audit.path, {
      session_id: sessionId,
      hook_event: 'PreToolUse',
      tool_name: toolName,
      action: 'deny',
      operation_preview: previewStr,
      _preview_chars: config.audit.command_preview_chars || 120,
      rule_id: result.ruleId,
      rule_label: result.ruleId,
      risk: result.risk,
      reason: result.reason,
      policy_preset: config.preset,
      project: process.env.KNOX_PROJECT_DIR || process.env.CLAUDE_PROJECT_DIR || process.cwd()
    });

    // Escalation tracking
    let additionalCtx = null;
    if (!isCheckDisabled(config, 'escalation_tracking')) {
      const state = incrementDenial(sessionId, config.escalation.session_threshold);
      const crossCount = recordCrossDenial(sessionId, config.escalation.agent_window_hours);
      if (state.flagged || crossCount >= config.escalation.agent_threshold) {
        additionalCtx = `Knox ESCALATION: ${state.denial_count} denial(s) this session. Cross-session: ${crossCount}/${config.escalation.agent_threshold} (${config.escalation.agent_window_hours}h). Security policy is active and working correctly.`;
      }
    }

    if (isCritical) {
      // exit 2 for critical — hard block, bypasses deny-ignore bug
      process.stderr.write(result.reason + '\n');
      process.exit(2);
    }

    const decision = config.use_ask_not_deny ? 'ask' : 'deny';
    const response = {
      hookSpecificOutput: {
        hookEventName: 'PreToolUse',
        permissionDecision: decision,
        permissionDecisionReason: result.reason
      }
    };
    if (additionalCtx) response.hookSpecificOutput.additionalContext = additionalCtx;
    process.stdout.write(JSON.stringify(response) + '\n');
    process.exit(0);
  }

  if (result && result.sanitized) {
    // Return sanitized command via updatedInput
    const response = {
      hookSpecificOutput: {
        hookEventName: 'PreToolUse',
        permissionDecision: 'allow',
        permissionDecisionReason: result.reason,
        updatedInput: { command: result.sanitizedCommand }
      }
    };
    process.stdout.write(JSON.stringify(response) + '\n');
    process.exit(0);
  }

  // Audit allowed commands if configured
  if (config.audit.include_allowed) {
    writeAudit(config.audit.path, {
      session_id: sessionId,
      hook_event: 'PreToolUse',
      tool_name: toolName,
      action: 'allow',
      operation_preview: input.command || input.file_path || '',
      _preview_chars: config.audit.command_preview_chars || 120,
      policy_preset: config.preset,
      project: process.env.KNOX_PROJECT_DIR || process.env.CLAUDE_PROJECT_DIR || process.cwd()
    });
  }

  // Allow — exit 0 with no JSON
  process.exit(0);
});

function extractStringValues(obj, depth) {
  if (!depth) depth = 0;
  if (depth > 3) return [];
  if (typeof obj === 'string') return [obj];
  if (Array.isArray(obj)) return obj.flatMap(v => extractStringValues(v, depth + 1));
  if (obj && typeof obj === 'object') return Object.values(obj).flatMap(v => extractStringValues(v, depth + 1));
  return [];
}
